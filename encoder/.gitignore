# Rust build output
/target

# napi-rs build artifacts
*.node
index.js
index.d.ts

# Downloaded third-party scene content (Decentraland production bundles
# pulled by scripts/download-scenes.sh) — these are NOT ours to commit.
# Keep the corpus out of version control; re-download on demand.
/downloaded-scenes
/corpus
*.assetbundle

# Bake output (shader manifests + typetree fixtures produced locally)
/output-bake

# TypeTree fixtures are NOT committed — they encode Unity engine type
# schemas (see the Legal & Licensing section of README.md). Regenerate
# them on demand with scripts/regenerate-fixtures.sh (CI does this before
# tests; devs run it before the verifiers).
/baked-fixtures/typetrees/*.bin
