{
  "name": "@dcl/asset-bundle-encoder",
  "version": "0.0.1",
  "description": "Standalone Decentraland Unity AssetBundle encoder (Rust + napi-rs)",
  "main": "index.js",
  "types": "index.d.ts",
  "private": true,
  "napi": {
    "name": "dcl-asset-bundle-encoder",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin"
      ]
    }
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "test": "cargo test --release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 18"
  }
}
