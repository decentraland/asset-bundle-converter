    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Where each cache probe was served from. Process-local hit-cache skips S3; S3 HEAD costs a round-trip. Higher hit-cache share is better.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
