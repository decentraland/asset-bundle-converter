        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ab_converter_asset_probe_hit_cache_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "process-local hit-cache",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ab_converter_asset_probe_head_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "s3 HEAD",
          "refId": "B"
